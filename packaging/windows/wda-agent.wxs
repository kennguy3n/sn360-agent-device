<?xml version="1.0" encoding="UTF-8"?>
<!--
  WiX 3.x installer manifest for Wazuh Desktop Agent.

  Build with:
      candle -nologo -dVersion=0.1.0 -dBinary=..\..\target\x86_64-pc-windows-msvc\release\wda-agent.exe wda-agent.wxs
      light  -nologo -ext WixUtilExtension -o wda-agent.msi wda-agent.wixobj

  See packaging\windows\build-msi.ps1 for a driver script that bakes
  the current version out of Cargo.toml.
-->
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi"
     xmlns:util="http://schemas.microsoft.com/wix/UtilExtension">
  <Product Id="*"
           Name="Wazuh Desktop Agent"
           Language="1033"
           Version="$(var.Version)"
           Manufacturer="Wazuh Desktop Agent Contributors"
           UpgradeCode="4b7e4b47-3e5d-4a9b-9f5f-8a7e0e1c0c11">

    <Package InstallerVersion="500"
             Compressed="yes"
             InstallScope="perMachine"
             Description="Wazuh Desktop Agent $(var.Version)"
             Comments="Lightweight Wazuh-compatible security agent"/>

    <MajorUpgrade DowngradeErrorMessage="A newer version of Wazuh Desktop Agent is already installed."/>
    <MediaTemplate EmbedCab="yes"/>

    <Property Id="ARPPRODUCTICON" Value="wda-agent.ico"/>

    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="INSTALLFOLDER" Name="WazuhDesktopAgent">
          <Directory Id="SCADIR" Name="sca"/>
        </Directory>
      </Directory>
      <Directory Id="CommonAppDataFolder">
        <Directory Id="WDA_DATA" Name="WazuhDesktopAgent"/>
      </Directory>
    </Directory>

    <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">
      <Component Id="AgentBinary" Guid="*">
        <File Id="AgentExe"
              Name="wda-agent.exe"
              Source="$(var.Binary)"
              KeyPath="yes"/>
        <ServiceInstall Id="WDAService"
                        Type="ownProcess"
                        Name="WazuhDesktopAgent"
                        DisplayName="Wazuh Desktop Agent"
                        Description="Lightweight Wazuh-compatible security agent."
                        Start="auto"
                        Account="LocalSystem"
                        ErrorControl="normal"
                        Arguments="--config &quot;[INSTALLFOLDER]config.yaml&quot;"
                        Vital="yes">
          <!-- Restart the service on any failure, with exponential-ish
               backoff matching the systemd RestartSec=5 behaviour. -->
          <util:ServiceConfig FirstFailureActionType="restart"
                              SecondFailureActionType="restart"
                              ThirdFailureActionType="restart"
                              RestartServiceDelayInSeconds="5"
                              ResetPeriodInDays="1"/>
        </ServiceInstall>
        <ServiceControl Id="WDAServiceControl"
                        Name="WazuhDesktopAgent"
                        Start="install"
                        Stop="both"
                        Remove="uninstall"
                        Wait="yes"/>
      </Component>

      <Component Id="ConfigFile" Guid="*">
        <File Id="ConfigYaml"
              Name="config.yaml"
              Source="..\config\config.yaml"
              KeyPath="yes">
          <!-- NeverOverwrite preserves operator edits on upgrade. -->
        </File>
      </Component>
    </ComponentGroup>

    <Feature Id="Complete"
             Title="Wazuh Desktop Agent"
             Level="1">
      <ComponentGroupRef Id="ProductComponents"/>
    </Feature>
  </Product>
</Wix>
